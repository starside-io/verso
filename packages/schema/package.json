{
  "name": "@starside-io/verso-schema",
  "version": "0.4.0",
  "description": "Zod schemas and TypeScript types for Verso decks, slides, and themes",
  "license": "Apache-2.0",
  "author": "starside.io",
  "homepage": "https://github.com/starside-io/verso#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/starside-io/verso.git",
    "directory": "packages/schema"
  },
  "bugs": {
    "url": "https://github.com/starside-io/verso/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./json-schema": {
      "types": "./dist/json-schema.d.ts",
      "import": "./dist/json-schema.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "zod": "3.24.1",
    "zod-to-json-schema": "3.24.1"
  },
  "devDependencies": {
    "tsup": "8.3.5",
    "typescript": "5.7.3",
    "vitest": "2.1.8"
  }
}
