{
  "name": "verso-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Verso: JSON-driven presentations with multi-audience path branching, polished PDF / HTML / PNG export, and a visual editor.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "starside.io",
  "homepage": "https://github.com/starside-io/verso#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/starside-io/verso.git"
  },
  "bugs": {
    "url": "https://github.com/starside-io/verso/issues"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "biome check .",
    "format": "biome format --write .",
    "clean": "turbo run clean && rm -rf node_modules",
    "changeset": "changeset",
    "version": "changeset version && pnpm install --lockfile-only",
    "release": "pnpm -r build && changeset publish && git push --follow-tags"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@changesets/changelog-github": "0.5.0",
    "@changesets/cli": "2.27.10",
    "@types/node": "22.10.5",
    "turbo": "2.3.3",
    "typescript": "5.7.3"
  }
}
